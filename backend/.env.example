
# 通用
ENV=production
API_BASE_URL=http://127.0.0.1:8000
SCREENSHOT_BASE_URL=http://127.0.0.1:8000/static/screenshots
STATIC=/static # 外部访问路径（URL 前缀）
OUT_DIR=./static/screenshots    # 本地输出目录
IMAGE_BASE_URL=/static/screenshots  # 图片访问 URL
DATA_DIR=data

# transcriber 相关配置
TRANSCRIBER_TYPE=deepgram

# 指定 fast-whisper 模型的大小
# 可选: tiny, base, small, medium, large-v1, large-v2, large-v3, large-v3-turbo
# 推荐: large-v3 (最高准确率, ~3 GB)
WHISPER_MODEL_SIZE=large-v3

# deepgram 配置 (当 TRANSCRIBER_TYPE=deepgram 时生效)
DEEPGRAM_API_KEY=test

# paraformer-streaming 配置 (当 TRANSCRIBER_TYPE=paraformer-streaming 时生效)
# 参数量: 220M
# 模型大小: 约 880 MB
# 支持语言: 中文（普通话）
# 流式支持: ✅ 是
# 延迟: 600ms（可配置）
PARAFORMER_USE_VAD=false   # VAD 在流式模式下不兼容（funasr 1.3.1 bug）
PARAFORMER_USE_PUNC=false  # 标点恢复在流式模式下不工作，建议后期用 GPT 添加标点

# Redis 配置
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB_TASK=0        # 任务状态
REDIS_DB_CACHE=1       # 缓存
REDIS_DB_QUEUE=2       # 任务队列

# 每批最多包含的图片数量（默认 8）
MAX_IMAGES_PER_BATCH=9

# 最大网格图总数（默认 30，现在可以设置更大）
MAX_VIDEO_GRIDS=45
