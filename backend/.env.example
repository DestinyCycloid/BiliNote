
# 通用
ENV=production
API_BASE_URL=http://127.0.0.1:8000
SCREENSHOT_BASE_URL=http://127.0.0.1:8000/static/screenshots
STATIC=/static # 外部访问路径（URL 前缀）
OUT_DIR=./static/screenshots    # 本地输出目录
IMAGE_BASE_URL=/static/screenshots  # 图片访问 URL
DATA_DIR=data
# transcriber 相关配置
TRANSCRIBER_TYPE=fast-whisper # fast-whisper/bcut/kuaishou/paraformer-streaming/deepgram/qwen3-asr
# 指定 Faster-Whisper 模型的大小
# 可选: tiny, base, small, medium, large-v1, large-v2, large-v3, large-v3-turbo
# 推荐: large-v3 (最高准确率, ~3 GB)
WHISPER_MODEL_SIZE=large-v3

# Qwen3-ASR 配置（当 TRANSCRIBER_TYPE=qwen3-asr 时生效）
# 远程服务地址（如果配置了，将使用远程模式；否则使用本地模式）
# 远程模式：适用于 Windows，调用 WSL2 上的服务
# 本地模式：适用于 Linux，直接运行模型（需要 vLLM）
QWEN3_ASR_REMOTE_URL=http://172.28.176.123:8765

# 模型选择（本地模式）: Qwen/Qwen3-ASR-1.7B (推荐) 或 Qwen/Qwen3-ASR-0.6B (轻量级)
QWEN3_ASR_MODEL=Qwen/Qwen3-ASR-1.7B
# 后端选择（本地模式）: vllm (推荐) 或 transformers (基础)
QWEN3_ASR_BACKEND=vllm
# 是否使用强制对齐器生成时间戳: true 或 false
QWEN3_ASR_USE_ALIGNER=false